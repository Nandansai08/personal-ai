{
  "name": "@nandansai08/personal-ai",
  "version": "1.0.0",
  "description": "Personal AI assistant — any model, local or cloud",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "web": "tsx src/web.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/ui/web/client','dist/ui/web/client',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "prepublishOnly": "npm run build && npm test && npm run typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "js-yaml": "^4.2.0",
    "openai": "^6.42.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chokidar": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "^3.2.6",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  },
  "bin": {
    "personal-ai": "bin/personal-ai.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin",
    "config",
    ".env.example",
    "plugins",
    "docs/PLUGINS.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nandansai08/personal-ai.git"
  },
  "homepage": "https://github.com/Nandansai08/personal-ai#readme",
  "bugs": {
    "url": "https://github.com/Nandansai08/personal-ai/issues"
  },
  "keywords": [
    "ai",
    "assistant",
    "local-first",
    "ollama",
    "llm",
    "chatgpt",
    "claude",
    "cli",
    "memory",
    "semantic-search",
    "privacy"
  ]
}
