# Personal AI — copy to .env and fill in what you use.

# ── Ollama (local, no key needed) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_NUM_CTX=4096        # reduce to 2048 for faster responses on low RAM
OLLAMA_NUM_PREDICT=512     # max output tokens per response
OLLAMA_TEMPERATURE=0.7

# ── Logging ──────────────────────────────────────────────────────────
# LOG_LEVEL=info        # debug | info | warn | error  (default: info)

# ── Anthropic ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Groq ─────────────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── Google Gemini ─────────────────────────────────────────────────────
# GEMINI_API_KEY=AIza...

# ── Mistral ──────────────────────────────────────────────────────────
# MISTRAL_API_KEY=...
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── LM Studio ────────────────────────────────────────────────────────
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ── Together.ai ──────────────────────────────────────────────────────
# TOGETHER_API_KEY=...

# ── Web Search ───────────────────────────────────────────────────────
# Priority: Serper → Brave → DuckDuckGo
SERPER_API_KEY=          # free 2500 searches, no card — https://serper.dev
# BRAVE_SEARCH_API_KEY=  # free 2000/month — https://api.search.brave.com
